{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users (Donors and Beneficiaries)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["donor", "beneficiary", "admin"] },
        "idFrontUrl": { "type": "string" },
        "idBackUrl": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "totalDonated": { "type": "number" },
        "ratingCount": { "type": "number" },
        "ratingSum": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "email": { "type": "string" }
      },
      "required": ["uid", "name", "phone", "role"]
    },
    "Case": {
      "title": "Case",
      "description": "Financial help requests from beneficiaries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "beneficiaryId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "verifiedBy": { "type": "string" }
      },
      "required": ["beneficiaryId", "title", "description", "targetAmount", "currentAmount", "status"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Contributions from donors to cases",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "caseId": { "type": "string" },
        "donorId": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "donorId", "amount"]
    },
    "Rating": {
      "title": "Rating",
      "description": "Ratings given to donors by beneficiaries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorId": { "type": "string" },
        "beneficiaryId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["donorId", "beneficiaryId", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Help request cases"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Donation records"
    },
    "/ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Donor ratings"
    }
  }
}
