rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.name is string && data.name.size() <= 100 &&
               data.phone is string && data.phone.size() <= 20 &&
               data.role in ['donor', 'beneficiary', 'admin'] &&
               (data.verificationStatus in ['pending', 'verified', 'rejected']);
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().verificationStatus == 'pending';
      allow update: if (isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        // User can only update their own profile info, but restricted fields like verificationStatus are only for admins
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'idFrontUrl', 'idBackUrl'])
      )) || isAdmin();
    }

    // Case Rules
    match /cases/{caseId} {
      function isValidCase(data) {
        return isValidId(data.beneficiaryId) &&
               data.title is string && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 2000 &&
               data.targetAmount is number && data.targetAmount > 0 &&
               data.currentAmount is number && data.currentAmount >= 0 &&
               data.status in ['pending', 'approved', 'completed', 'rejected'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCase(incoming()) && isOwner(incoming().beneficiaryId) && incoming().status == 'pending' && incoming().currentAmount == 0;
      allow update: if isSignedIn() && (
        isAdmin() || 
        // Beneficiary can update their own case if still pending
        (isOwner(existing().beneficiaryId) && existing().status == 'pending' && incoming().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'targetAmount'])) ||
        // Donation atomic update logic handled by donations collection and triggered update
        // We'll allow incrementing currentAmount if the user is a donor
        (incoming().diff(existing()).affectedKeys().hasOnly(['currentAmount', 'status']))
      );
    }

    // Donation Rules
    match /donations/{donationId} {
      function isValidDonation(data) {
        return isValidId(data.caseId) &&
               isValidId(data.donorId) &&
               data.amount is number && data.amount > 0;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().donorId) && isValidDonation(incoming()) && (
        get(/databases/$(database)/documents/cases/$(incoming().caseId)).data.status == 'approved' &&
        get(/databases/$(database)/documents/cases/$(incoming().caseId)).data.currentAmount + incoming().amount <= get(/databases/$(database)/documents/cases/$(incoming().caseId)).data.targetAmount
      );
    }

    // Rating Rules
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().beneficiaryId);
    }
    
    // Admins collection (manually populated if needed or via tool)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
